@model List<DocumentManagementSystem.Controllers.UserListViewModel>

@{
    ViewData["Title"] = "Users";
    var roles = ViewBag.Roles as List<DocumentManagementSystem.Models.Role> ?? new List<DocumentManagementSystem.Models.Role>();
    var currentUserId = ViewBag.CurrentUserId == null ? 0 : (int)ViewBag.CurrentUserId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>👥 Users</h2>
        <p class="text-muted mb-0">Manage users, roles and active status.</p>
    </div>

    <a asp-controller="User" asp-action="Create" class="btn btn-primary">
        ➕ Add New User
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card shadow">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th style="width: 330px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No users found.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var user in Model)
                    {
                        var isCurrentUser = user.Id == currentUserId;

                        <tr>
                            <td>
                                <strong>@user.Name</strong>

                                @if (isCurrentUser)
                                {
                                    <span class="badge bg-primary ms-1">You</span>
                                }
                            </td>

                            <td>@user.Email</td>

                            <td>
                                <span class="badge bg-secondary">@user.RoleName</span>
                            </td>

                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Passive</span>
                                }
                            </td>

                            <td>@user.CreatedAt.ToString("dd MMM yyyy")</td>

                            <td>
                                <div class="d-flex gap-2 flex-wrap">

                                    <form method="post" asp-controller="User" asp-action="ChangeRole" asp-route-id="@user.Id" class="d-flex gap-2">
                                        <select name="roleId" class="form-select form-select-sm" disabled="@isCurrentUser">
                                            @foreach (var role in roles)
                                            {
                                                <option value="@role.Id" selected="@(role.Id == user.RoleId)">
                                                    @role.RoleName
                                                </option>
                                            }
                                        </select>

                                        <button type="submit" class="btn btn-sm btn-outline-primary" disabled="@isCurrentUser">
                                            Save
                                        </button>
                                    </form>

                                    <form method="post" asp-controller="User" asp-action="ToggleActive" asp-route-id="@user.Id">
                                        <button type="submit"
                                                class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                disabled="@isCurrentUser"
                                                onclick="return confirm('Are you sure you want to change this user status?')">
                                            @(user.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>

                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>