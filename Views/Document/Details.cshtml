@model DocumentManagementSystem.Models.Document

@{
    ViewData["Title"] = "Document Details";

    var versions = ViewBag.Versions as List<DocumentManagementSystem.Models.DocumentVersion>
        ?? new List<DocumentManagementSystem.Models.DocumentVersion>();

    var logs = ViewBag.Logs as List<DocumentManagementSystem.Models.AuditLog>
        ?? new List<DocumentManagementSystem.Models.AuditLog>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📄 @Model.Title</h2>

    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin") || User.IsInRole("Engineer") || User.IsInRole("Quality"))
        {
            <a asp-action="UploadNewVersion" asp-route-id="@Model.Id" class="btn btn-primary">
                ⬆️ Upload New Version
            </a>
        }

        <a asp-action="Index" class="btn btn-outline-secondary">
            ← Back to Documents
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header">
                <strong>Document Information</strong>
            </div>

            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="text-muted" style="width:180px">Title</td>
                        <td><strong>@Model.Title</strong></td>
                    </tr>

                    <tr>
                        <td class="text-muted">Document Type</td>
                        <td><span class="badge bg-secondary">@Model.DocumentType</span></td>
                    </tr>

                    <tr>
                        <td class="text-muted">Aircraft Type</td>
                        <td>@Model.AircraftType</td>
                    </tr>

                    <tr>
                        <td class="text-muted">ATA Chapter</td>
                        <td>@Model.ATAChapter</td>
                    </tr>

                    <tr>
                        <td class="text-muted">Status</td>
                        <td>
                            @switch (Model.Status)
                            {
                                case DocumentManagementSystem.Models.DocumentStatus.Approved:
                                    <span class="badge bg-success">Approved</span>
                                    break;

                                case DocumentManagementSystem.Models.DocumentStatus.Draft:
                                    <span class="badge bg-warning text-dark">Draft</span>
                                    break;

                                case DocumentManagementSystem.Models.DocumentStatus.InReview:
                                    <span class="badge bg-info">In Review</span>
                                    break;

                                default:
                                    <span class="badge bg-danger">Rejected</span>
                                    break;
                            }
                        </td>
                    </tr>

                    <tr>
                        <td class="text-muted">Created At</td>
                        <td>@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                </table>

                <div class="mt-3 d-flex gap-2 flex-wrap">
                    @if (User.IsInRole("Admin") || User.IsInRole("Quality"))
                    {
                        <form method="post" asp-action="ChangeStatus" asp-route-id="@Model.Id">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="status" value="InReview" />
                            <button type="submit"
                                    class="btn btn-sm btn-info"
                                    disabled="@(Model.Status == DocumentManagementSystem.Models.DocumentStatus.InReview ||
                                                                                    Model.Status == DocumentManagementSystem.Models.DocumentStatus.Approved)">
                                Submit for Review
                            </button>
                        </form>

                        <form method="post" asp-action="ChangeStatus" asp-route-id="@Model.Id">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="status" value="Approved" />
                            <button type="submit"
                                    class="btn btn-sm btn-success"
                                    disabled="@(Model.Status != DocumentManagementSystem.Models.DocumentStatus.InReview)">
                                Approve
                            </button>
                        </form>

                        <form method="post" asp-action="ChangeStatus" asp-route-id="@Model.Id">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="status" value="Rejected" />
                            <button type="submit"
                                    class="btn btn-sm btn-warning"
                                    disabled="@(Model.Status != DocumentManagementSystem.Models.DocumentStatus.InReview)">
                                Reject
                            </button>
                        </form>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <form method="post"
                              asp-action="Delete"
                              asp-route-id="@Model.Id"
                              onsubmit="return confirm('Are you sure you want to delete this document?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">
                                Delete
                            </button>
                        </form>
                    }
                </div>

                <div class="form-text mt-2">
                    Workflow: Draft → In Review → Approved / Rejected
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-header">
        <strong>🔄 Document Versions</strong>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Version</th>
                    <th>File Type</th>
                    <th>File Size</th>
                    <th>Status</th>
                    <th>Uploaded At</th>
                    <th>Download</th>
                </tr>
            </thead>

            <tbody>
                @if (versions.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No versions found.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var v in versions)
                    {
                        <tr>
                            <td>
                                @($"v{v.VersionNumber}")

                                @if (v.Id == Model.CurrentVersionId)
                                {
                                    <span class="badge bg-success ms-1">Current</span>
                                }
                            </td>

                            <td>
                                <span class="badge bg-secondary">@v.FileType</span>
                            </td>

                            <td>
                                @(Math.Round(v.FileSize / 1024.0, 1)) KB
                            </td>

                            <td>
                                @if (v.IsObsolete)
                                {
                                    <span class="badge bg-danger">Obsolete</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </td>

                            <td>
                                @v.UploadedAt.ToString("dd MMM yyyy HH:mm")
                            </td>

                            <td>
                                <a href="@v.FilePath"
                                   class="btn btn-sm btn-outline-primary"
                                   download>
                                    ⬇️ Download
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card shadow">
    <div class="card-header">
        <strong>📋 Activity Log</strong>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Action</th>
                    <th>IP Address</th>
                    <th>Details</th>
                    <th>Time</th>
                </tr>
            </thead>

            <tbody>
                @if (logs.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            No activity found.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var log in logs)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-info">@log.ActionType</span>
                            </td>

                            <td>@log.IpAddress</td>

                            <td>@log.Details</td>

                            <td>@log.Timestamp.ToString("dd MMM yyyy HH:mm")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>