@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Aircraft DMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            body {
                background-color: #f4f6f9;
            }

            .sidebar {
                min-height: 100vh;
                background-color: #1a2035;
                width: 240px;
                position: fixed;
                top: 0;
                left: 0;
                padding-top: 20px;
                z-index: 100;
            }

                .sidebar .brand {
                    color: white;
                    font-size: 1rem;
                    font-weight: 700;
                    padding: 10px 20px 20px;
                    border-bottom: 1px solid #2d3a57;
                    margin-bottom: 10px;
                }

                .sidebar .nav-link {
                    color: #a0aec0;
                    padding: 10px 20px;
                    border-radius: 6px;
                    margin: 2px 10px;
                    transition: all 0.2s;
                }

                    .sidebar .nav-link:hover,
                    .sidebar .nav-link.active {
                        background-color: #2d3a57;
                        color: white;
                    }

            .main-content {
                margin-left: 240px;
                padding: 30px;
            }

            .topbar {
                background: white;
                padding: 12px 30px;
                margin-left: 240px;
                border-bottom: 1px solid #e2e8f0;
                display: flex;
                justify-content: flex-end;
                align-items: center;
                gap: 15px;
            }
    </style>
</head>
<body>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="sidebar">
            <div class="brand">✈️ Aircraft DMS</div>

            <nav class="nav flex-column">
                <a class="nav-link @(currentController == "Home" ? "active" : "")"
                   asp-controller="Home"
                   asp-action="Index">
                    🏠 Dashboard
                </a>

                <a class="nav-link @(currentController == "Document" && currentAction != "Upload" ? "active" : "")"
                   asp-controller="Document"
                   asp-action="Index">
                    📄 Documents
                </a>

                @if (User.IsInRole("Admin") || User.IsInRole("Engineer") || User.IsInRole("Quality"))
                {
                    <a class="nav-link @(currentController == "Document" && currentAction == "Upload" ? "active" : "")"
                       asp-controller="Document"
                       asp-action="Upload">
                        ⬆️ Upload Document
                    </a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a class="nav-link @(currentController == "User" ? "active" : "")"
                       asp-controller="User"
                       asp-action="Index">
                        👥 Users
                    </a>

                    <a class="nav-link @(currentController == "AuditLog" ? "active" : "")"
                       asp-controller="AuditLog"
                       asp-action="Index">
                        📋 Audit Logs
                    </a>
                }
            </nav>
        </div>

        <div class="topbar">
            <span class="text-muted">👤 @User.Identity.Name</span>

            <a asp-controller="Account"
               asp-action="Logout"
               class="btn btn-sm btn-outline-danger">
                Logout
            </a>
        </div>

        <div class="main-content">
            @RenderBody()
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>